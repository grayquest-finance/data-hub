PORT=8080
X_API_KEY=

ADMIN_BASE_URL=https://admin-api.uat.graydev.in
ADMIN_API_KEY=

KYC_BASE_URL=https://svc-kyc.uat.graydev.in
KYC_API_KEY=

SERVICES_BASE_URL=https://services.uat.graydev.in
SERVICES_API_KEY=

REDIS_ADDR=redis.graydev.infra:6379
CACHE_ENABLED=false

# Cache TTLs — use Go duration format: 2h, 30m, 5m, etc.
# If not set, defaults are used (see config/config.go)
CACHE_TTL_DISBURSEMENT=2h
CACHE_TTL_REPAYMENT=30m
CACHE_TTL_MANDATE=15m
CACHE_TTL_PAYMENTS=5m
CACHE_TTL_KYC=1h
CACHE_TTL_APPLICATION=5m
CACHE_TTL_REFUND=15m
CACHE_TTL_DOCUMENTS=1h
